# ===========================================
# Distributed Log System - Environment Config
# ===========================================
# Copy this file to .env and adjust values

# Node
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# PostgreSQL
DATABASE_URL=postgresql://dlsuser:dlspassword@localhost:5432/distributed_logs
DB_HOST=localhost
DB_PORT=5432
DB_USER=dlsuser
DB_PASSWORD=dlspassword
DB_NAME=distributed_logs

# Service Ports
INGESTION_PORT=3001
PROCESSING_WORKERS=2
QUERY_PORT=3003
DASHBOARD_PORT=3000

# Redis Stream Config
STREAM_NAME=stream:raw-logs
CONSUMER_GROUP=log-processors
STREAM_MAX_LEN=100000

# Log Retention (days)
LOG_RETENTION_DAYS=30
